# Copy this file to .env and fill in your API keys

# JSearch API (RapidAPI) - Free tier: 200 requests/month
# Sign up at https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=your_rapidapi_key_here

# Adzuna API - Free tier: 500 calls/month
# Sign up at https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_API_KEY=your_adzuna_api_key

# OpenRouter API (optional - for AI classification)
# Sign up at https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_key_here

# Database path (default: data/semijobs.db)
DB_PATH=data/semijobs.db
